{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://c3.blckrbbt.io/:path*",
      "comment": "Phase C of C3-56: point at Vercel-hosted public API"
    }
  ],
  "headers": [
    {
      "source": "/api/:path*",
      "headers": [
        {
          "key": "X-C3-Rewrite-Source",
          "value": "vercel-public-ui"
        }
      ]
    }
  ]
}